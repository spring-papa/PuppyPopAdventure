rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedInAs(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function validProfile() {
      return request.resource.data.keys().hasOnly(['displayName', 'email', 'createdAt', 'updatedAt'])
        && request.resource.data.displayName is string
        && request.resource.data.email is string;
    }

    function validProgress() {
      return request.resource.data.keys().hasOnly([
        'schemaVersion',
        'maxUnlockedStage',
        'unlockedItems',
        'equippedItems',
        'bestSnacks',
        'updatedAt',
        'savedAt'
      ])
        && request.resource.data.schemaVersion == 1
        && request.resource.data.maxUnlockedStage is int
        && request.resource.data.maxUnlockedStage >= 0
        && request.resource.data.bestSnacks is int
        && request.resource.data.bestSnacks >= 0
        && request.resource.data.unlockedItems is list
        && request.resource.data.equippedItems is list
        && request.resource.data.updatedAt is string;
    }

    match /users/{userId} {
      allow read: if signedInAs(userId);
      allow create, update: if signedInAs(userId) && validProfile();
      allow delete: if false;

      match /progress/{progressId} {
        allow read: if signedInAs(userId);
        allow create, update: if signedInAs(userId) && progressId == 'current' && validProgress();
        allow delete: if false;
      }
    }
  }
}
